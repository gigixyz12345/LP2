public class Maths {

    public static void operations() {
        // Initializing the array with 3 values inside the program
        Integer[] nums = new Integer[]{20, 10, 5};

        // Standard Operations using array indices
        Integer add = nums[0] + nums[1];
        Integer sub = nums[0] - nums[1];
        Integer mul = nums[0] * nums[1];
        Integer div = nums[0] / nums[1];

        System.debug('Array used: ' + nums);
        System.debug('Addition: ' + add);
        System.debug('Subtraction: ' + sub);
        System.debug('Multiplication: ' + mul);
        System.debug('Division: ' + div);
        
        // Multiplication Table for the first element in the array (nums[0])
        Integer tableNum = nums[2];
        System.debug('Multiplication Table for: ' + tableNum);
        
        for (Integer i = 1; i <= 10; i++) {
            System.debug(tableNum + ' x ' + i + ' = ' + (tableNum * i));
        }
    }
}
